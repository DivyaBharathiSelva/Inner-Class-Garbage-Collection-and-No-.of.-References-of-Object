import sys
class Supplier:
    def __init__(self, name):
        self.name = name
    def display_supplier(self):
        print("Supplier Name:", self.name)
class Product:
    def __init__(self, name, price, supplier, spec_details):
        self.name = name
        self.price = price
        self.supplier = supplier
        self.spec = self.Specification(spec_details)
    class Specification:
        def __init__(self, details):
            self.details = details
        def display_spec(self):
            print("Specifications:", self.details)
    def display_product(self):
        print("\n--- Product Details ---")
        print("Product Name:", self.name)
        print("Price:", self.price)
        self.supplier.display_supplier()
        self.spec.display_spec()
    def show_reference_count(self):
        print("\n--- Reference Count ---")
        print("Product Reference Count:", sys.getrefcount(self))
        print("Supplier Reference Count:", sys.getrefcount(self.supplier))
n = int(input("Enter number of products: "))
products = []
for i in range(n):
    print(f"\nEnter details for Product {i+1}")

    pname = input("Enter product name: ")
    price = float(input("Enter price: "))
    sname = input("Enter supplier name: ")
    spec = input("Enter specifications: ")
    supplier = Supplier(sname)
    product = Product(pname, price, supplier, spec)
    products.append(product)
print("\n===== INVENTORY DETAILS =====")
for p in products:
    p.display_product()
    p.show_reference_count()
