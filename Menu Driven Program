import sys
import gc
class University:
    def __init__(self, name):
        self.university_name = name
        self.students = []
    def add_student(self):
        rollno = int(input("Enter Roll No: "))
        name = input("Enter Name: ")
        s = self.Student(rollno, name, self)
        self.students.append(s)
        print("Student added")
        print("Reference count:", sys.getrefcount(s))
    def remove_student(self):
        rollno = int(input("Enter Roll No to delete: "))
        for s in self.students:
            if s.rollno == rollno:
                print("Deleting:", s.name)
                print("Reference before delete:", sys.getrefcount(s))

                self.students.remove(s)
                del s
                gc.collect()
                print("Student deleted")
                return
        print("Student not found")
    def display_all(self):
        print("\nStudent List:")
        for s in self.students:
            s.display_details()
            print("-------------")
    class Student:
        def __init__(self, rollno, name, university):
            self.rollno = rollno
            self.name = name
            self.university = university
        def display_details(self):
            print("Roll No:", self.rollno)
            print("Name:", self.name)
            print("University:", self.university.university_name)
gc.enable()
uname = input("Enter University Name: ")
u = University(uname)
while True:
    print("\n1. Add Student")
    print("2. Remove Student")
    print("3. Display Students")
    print("4. Exit")

    ch = int(input("Enter choice: "))

    if ch == 1:
        u.add_student()
    elif ch == 2:
        u.remove_student()
    elif ch == 3:
        u.display_all()
    elif ch == 4:
        print("GC Info:", gc.get_count())
        break
    else:
        print("Invalid choice")
